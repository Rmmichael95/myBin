#!/usr/bin/dash

# 1. Loop through $PATH, find executables, sort them, and pipe to bemenu
selected=$(
    IFS=:
    for dir in $PATH; do
        [ -d "$dir" ] || continue
        for file in "$dir"/*; do
            [ -x "$file" ] && [ ! -d "$file" ] && echo "${file##*/}"
        done
    done 2>/dev/null | sort -u | bemenu --prompt ">" --ignorecase --line-height 55 --counter "always" --fn "JetBrainsMonoNerdFontMono 20" --tb "#15191c" --tf "#eb4d4b" --fb "#15191c" --ff "#d3c6aa" --nb "#15191c" --nf "#4b565c" --hb "#15191c" --hf "#d3c6aa" --fbb "#15191c" --fbf "#d3c6aa" --sb "#15191c" --sf "#d3c6aa" --ab "#15191c" --af "#4b565c" --bdr "#4b565c"
)

# 2. Check if the user selected an item
if [ -n "$selected" ]; then
    # 3. Use eval to correctly parse arguments (like quotes) and execute via uwsm
    eval "exec uwsm app -- $selected"
fi
