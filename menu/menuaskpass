#!/bin/sh
# ~/.local/bin/myBin/menu/dmenupass
#
# SUDO_ASKPASS script for sudo-rs (and sudo -A).
# Called by sudo-rs when it needs a graphical password prompt.
# Must print the password to stdout and exit 0, or exit non-zero on cancel.

bemenu \
    --prompt "${1:-Password:}" \
    --password hide \
    --ignorecase \
    --line-height 55 \
    --fn "JetBrainsMonoNerdFontMono 20" \
    --tb "#15191c" --tf "#eb4d4b" \
    --fb "#15191c" --ff "#d3c6aa" \
    --nb "#15191c" --nf "#4b565c" \
    --hb "#15191c" --hf "#d3c6aa" \
    --fbb "#15191c" --fbf "#d3c6aa" \
    --sb "#15191c" --sf "#d3c6aa" \
    --ab "#15191c" --af "#4b565c" \
    --bdr "#4b565c"
