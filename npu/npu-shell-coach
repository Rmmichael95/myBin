#!/usr/bin/env zsh
# Real-time NPU Terminal Coach - Full Matrix Context Engine

[[ -f "$HOME/.profile" ]] && source "$HOME/.profile"

local HISTORY_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
local ALIAS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/shell/aliasrc"

until curl -s -o /dev/null "http://127.0.0.1:52625/v1/models"; do
    sleep 3
done

echo "NPU Shell Coach active. Monitoring history with full alias matrix context..."

local LAST_CMD=""

inotifywait -m -e modify,close_write,moved_to --format '%w%f' "$HISTORY_FILE" | while read -r FILE; do
    RAW_CMD=$(tail -n 1 "$HISTORY_FILE" | sed 's/^: *[0-9]*:[0-9]*;//')

    if [[ -z "${RAW_CMD// }" ]] || [[ ${#RAW_CMD} -lt 5 ]]; then
        continue
    fi
    if [[ "$RAW_CMD" =~ ^(ls|cd|pwd|clear|journalctl)\  ]]; then
        continue
    fi

    if [[ "$RAW_CMD" == "$LAST_CMD" ]]; then
        continue
    fi
    LAST_CMD="$RAW_CMD"

    # INGEST THE ENTIRE ALIAS MATRIX DIRECTLY INTO MEMORY
    local ALIAS_MATRIX=""
    [[ -f "$ALIAS_FILE" ]] && ALIAS_MATRIX=$(cat "$ALIAS_FILE" | grep -v '^#' | grep -v '^$')

    SYS_PROMPT="You are a strict terminal optimization engine. Review the user command.

FULL PERSONAL ALIAS MATRIX:
$ALIAS_MATRIX

CRITICAL INSTRUCTIONS:
1. ALIAS MATCHING: Review the FULL PERSONAL ALIAS MATRIX section. If the user's command matches the right side or core functional intent of any listed alias (even if they added 'sudo' or minor flags that your alias handles natively), you MUST instruct them to use that personal alias shortcut instead.
2. TARGETED UTILITIES: [find, grep, sed, cat]
3. If the user command contains 'find', convert it to 'fd'.
4. If the user command contains 'grep' (and is not ripgrep), convert it to 'rg'.
5. If the user command contains 'cat' piped into another tool, flag it as a Useless Use of Cat (UUOC).
6. OUTPUT FORMAT: Everything MUST be on a single line separated strictly by a literal pipe character ( | ). Do not use markdown backticks. Follow this exact template:
   Critique: [Explanation] | Legacy: [Original command] | Modern: [Optimized syntax or alias version]
7. If no optimizations or alias matches apply, output exactly: IGNORE"

    PAYLOAD=$(jq -n \
        --arg model "llama3.1:8b" \
        --arg sys "$SYS_PROMPT" \
        --arg user "$RAW_CMD" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $sys},
                {role: "user", content: $user}
            ],
            temperature: 0.1,
            max_tokens: 120
        }')

    RESPONSE=$(curl -s http://127.0.0.1:52625/v1/chat/completions \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer ${FLM_API_KEY:-lemonade}" \
        -d "$PAYLOAD")

    AI_TEXT=$(echo "$RESPONSE" | jq -r '.choices[0].message.content' 2>/dev/null)

    if [[ -z "${AI_TEXT// }" || "$AI_TEXT" == "null" || "$AI_TEXT" == "IGNORE"* ]]; then
        continue
    fi

    # CLIENT-SIDE VERIFICATION GUARD
    local modern_val=$(echo "$AI_TEXT" | awk -F '|' '{for(i=1;i<=NF;i++) if($i ~ /Modern:/) print $i}' | sed 's/.*Modern: //;s/^[ \t]*//;s/[ \t]*$//')
    local legacy_val=$(echo "$AI_TEXT" | awk -F '|' '{for(i=1;i<=NF;i++) if($i ~ /Legacy:/) print $i}' | sed 's/.*Legacy: //;s/^[ \t]*//;s/[ \t]*$//')

    if [[ -z "$modern_val" || "$modern_val" == "$RAW_CMD" || "$modern_val" == "$legacy_val" ]]; then
        continue
    fi

    echo "Evaluated: $RAW_CMD | Response: $AI_TEXT"

    CLEAN_NOTIFY=$(echo "$AI_TEXT" | sed 's/ | /\n/g')
    notify-send -u normal -t 9000 -a "NPU Shell Coach" "💡 Command Optimization" "$CLEAN_NOTIFY"
done
