#!/usr/bin/env zsh
# Real-time NPU Terminal Coach - Qwen 3.5 High-Speed Reflex Engine

[[ -f "$HOME/.profile" ]] && source "$HOME/.profile"

local HISTORY_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
local ALIAS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/shell/aliasrc"

until curl -s -o /dev/null "http://127.0.0.1:52625/v1/models"; do
    sleep 3
done

echo "NPU Shell Coach active. Monitoring with hardened Qwen Reflex guards..."

local LAST_CMD=""

inotifywait -m -e modify,close_write,moved_to --format '%w%f' "$HISTORY_FILE" |
while read -r FILE; do
    RAW_CMD=$(tail -n 1 "$HISTORY_FILE" | sed 's/^: *[0-9]*:[0-9]*;//')

    # HARD FILTER LAYERS (Bypass trivial commands instantly)
    if [[ -z "${RAW_CMD// }" ]] || [[ ${#RAW_CMD} -lt 5 ]]; then
        continue
    fi
    if [[ "$RAW_CMD" =~ ^(ls|cd|pwd|clear|journalctl|rg)\  ]]; then
        continue
    fi
    if [[ "$RAW_CMD" == "$LAST_CMD" ]]; then
        continue
    fi
    LAST_CMD="$RAW_CMD"

    local ALIAS_MATRIX=""
    [[ -f "$ALIAS_FILE" ]] && ALIAS_MATRIX=$(cat "$ALIAS_FILE" | grep -v '^#' | grep -v '^$')

    SYS_PROMPT="You are a strict terminal optimization engine running alongside an Arch Linux environment. Review the user's raw command.

FULL PERSONAL ALIAS MATRIX:
$ALIAS_MATRIX

FEW-SHOT LOGICAL EXAMPLES FOR INTELLECTUAL PATTERN MATCHING:
- Input: pacman -Ss ripgrep
  Expected Output: Critique: Searching syncdb can be done with your personal alias shortcut. | Legacy: pacman -Ss ripgrep | Modern: pss ripgrep
- Input: sudo pacman -Syu
  Expected Output: Critique: Complete system upgrade maps cleanly to your shortcut matrix. | Legacy: sudo pacman -Syu | Modern: psu
- Input: grep -i 'error' system.log
  Expected Output: Critique: Ripgrep (rg) is a significantly faster modern recursive utility. | Legacy: grep -i 'error' system.log | Modern: rg -i 'error' system.log
- Input: psu
  Expected Output: IGNORE

CRITICAL INSTRUCTIONS (STRICT HIERARCHY):
1. PRIORITY 1 - TOTAL ALIAS MATCH: Carefully examine the functional intent of the input against the full personal alias matrix (especially matching pacman wrappers like psu, pss, psi). If an exact or partial match exists, you MUST output the 'Modern:' token mapped directly to that alias shortcut.
2. PRIORITY 2 - MODERN SYSTEM BINARIES: If no personal alias covers the command, catch legacy utilities and swap them (e.g., find -> fd, grep -> rg, sed -> sd).
3. OUTPUT FORMAT: Everything MUST be on a single line separated strictly by a literal pipe character ( | ). Do not use markdown backticks. Follow this exact template:
   Critique: [Explanation] | Legacy: [Original command] | Modern: [Optimized syntax or alias version]
4. If no optimizations or alias matches apply, output exactly: IGNORE"

    # COMPILING PAYLOAD WITH COMPACT REFLEX PROFILE
    PAYLOAD=$(jq -n \
        --arg model "qwen3.5:4b" \
        --arg sys "$SYS_PROMPT" \
        --arg user "$RAW_CMD" \
        --arg re "none" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $sys},
                {role: "user", content: $user}
            ],
            temperature: 0.1,
            max_tokens: 120,
            reasoning_effort: $re
        }')

    RESPONSE=$(curl -s http://127.0.0.1:52625/v1/chat/completions \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer ${FLM_API_KEY:-lemonade}" \
        -d "$PAYLOAD")

    AI_TEXT=$(echo "$RESPONSE" | jq -r '.choices[0].message.content' 2>/dev/null)

    if [[ -z "${AI_TEXT// }" || "$AI_TEXT" == "null" || "$AI_TEXT" == "IGNORE"* ]]; then
        continue
    fi

    # EXTRACT VALUES FROM THE PIPE GRID
    local modern_val=$(echo "$AI_TEXT" | awk -F '|' '{for(i=1;i<=NF;i++) if($i ~ /Modern:/) print $i}' | sed 's/.*Modern: //;s/^[ \t]*//;s/[ \t]*$//')
    local legacy_val=$(echo "$AI_TEXT" | awk -F '|' '{for(i=1;i<=NF;i++) if($i ~ /Legacy:/) print $i}' | sed 's/.*Legacy: //;s/^[ \t]*//;s/[ \t]*$//')

    # HARDENED VERIFICATION GUARD
    if [[ -z "$modern_val" || "$modern_val" == "$RAW_CMD" || "$modern_val" == "$legacy_val" || "${modern_val:u}" == *"IGNORE"* ]]; then
        continue
    fi

    echo "Evaluated: $RAW_CMD | Response: $AI_TEXT"

    CLEAN_NOTIFY=$(echo "$AI_TEXT" | sed 's/ | /\n/g')
    notify-send -u normal -t 9000 -a "NPU Shell Coach" "💡 Command Optimization" "$CLEAN_NOTIFY"
done
