#!/usr/bin/env zsh
# Real-time NPU Hierarchical Chunk Indexer for Neovim Notes

setopt EXTENDED_GLOB

local NOTES_DIR="$HOME/documents/.bc/batcave/Notes"
local VECTOR_CACHE="$HOME/.local/cache/npu_vectors"

mkdir -p "$VECTOR_CACHE" "$NOTES_DIR"
sleep 3

echo "NPU Granular Section Indexer active. Watching: $NOTES_DIR"

process_file() {
    local FILE="$1"
    local FILE_HASH=$(echo -n "$FILE" | md5sum | awk '{print $1}')

    # Store the tracking framework completely in a Zsh memory variable
    local CURRENT_JSON="{\"filepath\":\"$FILE\",\"chunks\":[]}"

    local current_header="Overview"
    local current_line=1
    local chunk_buffer=""
    local line_num=0

    while IFS= read -r line; do
        ((line_num++))

        if [[ "$line" =~ ^#+\ (.*) ]]; then
            if [[ -n "${chunk_buffer// }" ]]; then
                # Safe JSON compilation without relying on herestrings or /tmp
                local PAYLOAD=$(jq -n --arg model "embed-gemma:300m" --arg input "$chunk_buffer" '{model: $model, input: $input}')

                local RAW_JSON=$(curl -s http://127.0.0.1:52625/v1/embeddings \
                    -H "Content-Type: application/json" \
                    -H "Authorization: Bearer ${FLM_API_KEY:-lemonade}" \
                    -d "$PAYLOAD")

                local EMBEDDING=$(echo "$RAW_JSON" | jq '.data[0].embedding')

                if [[ "$EMBEDDING" != "null" && -n "$EMBEDDING" ]]; then
                    # Mutate the Zsh variable in memory
                    CURRENT_JSON=$(echo "$CURRENT_JSON" | jq --argjson line "$current_line" \
                       --arg head "$current_header" \
                       --argjson emb "$EMBEDDING" \
                       '.chunks += [{"line": $line, "header": $head, "embedding": $emb}]')
                fi
            fi

            current_header="${match[1]}"
            current_line=$line_num
            chunk_buffer="$line"
        else
            chunk_buffer+=$'\n'"$line"
        fi
    done < "$FILE"

    # Process trailing block
    if [[ -n "${chunk_buffer// }" ]]; then
        local PAYLOAD=$(jq -n --arg model "embed-gemma:300m" --arg input "$chunk_buffer" '{model: $model, input: $input}')
        local RAW_JSON=$(curl -s http://127.0.0.1:52625/v1/embeddings \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer ${FLM_API_KEY:-lemonade}" \
            -d "$PAYLOAD")
        local EMBEDDING=$(echo "$RAW_JSON" | jq '.data[0].embedding')

        if [[ "$EMBEDDING" != "null" && -n "$EMBEDDING" ]]; then
            CURRENT_JSON=$(echo "$CURRENT_JSON" | jq --argjson line "$current_line" \
               --arg head "$current_header" \
               --argjson emb "$EMBEDDING" \
               '.chunks += [{"line": $line, "header": $head, "embedding": $emb}]')
        fi
    fi

    # Write out the completed multi-vector object to your local cache
    echo "$CURRENT_JSON" > "$VECTOR_CACHE/${FILE_HASH}.json"
    logger -t npu_indexer "Generated structural sections for ${FILE:t}"
}

inotifywait -m -r -e close_write,moved_to --format '%w%f' "$NOTES_DIR" | while read -r FILE; do
    if [[ "$FILE" == *.md ]]; then
        process_file "$FILE"
    fi
done
